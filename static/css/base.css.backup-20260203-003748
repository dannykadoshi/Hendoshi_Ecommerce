    box-shadow: 0 4px 15px rgba(255, 20, 147, 0.3);
}

.vault-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 20, 147, 0.4);
}

/* Vault Featured Photos Carousel */
.vault-featured-section {
