/* Delete Confirmation Modal */
.delete-confirm-modal {
    background-color: var(--charcoal);
    border: 2px solid #dc3545;
    border-radius: 15px;
    color: var(--off-white);
}

.delete-confirm-modal .modal-header {
    background: rgba(220, 53, 69, 0.15);
    border-bottom: 2px solid #dc3545;
    padding: 1.25rem 1.5rem;
}

.delete-confirm-modal .modal-title {
    color: #dc3545;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 1.1rem;
}

.delete-confirm-modal .modal-title i {
    margin-right: 0.5rem;
}

.delete-confirm-modal .modal-body {
    padding: 2rem;
}

.delete-icon-wrapper {
    width: 80px;
    height: 80px;
    background: rgba(220, 53, 69, 0.15);
    border: 3px solid #dc3545;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    animation: pulse-danger 2s infinite;
}

.delete-icon-wrapper i {
    font-size: 2rem;
    color: #dc3545;
}

@keyframes pulse-danger {
    0%, 100% {
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4);
    }
    50% {
        box-shadow: 0 0 0 15px rgba(220, 53, 69, 0);
    }
}

.delete-message {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--off-white);
}

.delete-message strong {
    color: #dc3545;
    font-size: 1.3rem;
}

.delete-warning {
    color: #dc3545;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0;
}

.delete-warning i {
    margin-right: 0.5rem;
}

.delete-confirm-modal .modal-footer {
    border-top: 1px solid rgba(220, 53, 69, 0.3);
    padding: 1rem 1.5rem;
    gap: 1rem;
}

.delete-confirm-modal .btn-outline-secondary {
    background: transparent;
    border: 2px solid var(--gray);
    color: var(--off-white);
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.delete-confirm-modal .btn-outline-secondary:hover {
    background: var(--gray);
    color: var(--black);
}

.delete-confirm-modal .btn-danger {
    background: #dc3545;
    border: none;
    color: #fff;
    font-weight: 700;
    padding: 0.6rem 1.5rem;
    border-radius: 8px;
    transition: all 0.3s ease;
}

.delete-confirm-modal .btn-danger:hover {
    background: #c82333;
    box-shadow: 0 5px 20px rgba(220, 53, 69, 0.5);
    transform: translateY(-2px);
}

/* Light mode for delete modal */
:root.light-mode .delete-confirm-modal {
    background-color: #fff;
}

:root.light-mode .delete-confirm-modal .modal-body,
:root.light-mode .delete-message {
    color: #333;
}

