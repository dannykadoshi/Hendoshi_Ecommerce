    background: linear-gradient(135deg, #ff1493, var(--neon-pink));
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(255, 0, 127, 0.4);
    color: var(--white);
}

.cart-drawer-btn-checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: linear-gradient(135deg, #39ff14, #00ff7f);
    color: var(--black);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(57, 255, 20, 0.3);
    animation: glow 2s ease-in-out infinite alternate;
}

.cart-drawer-btn-checkout:hover {
    background: linear-gradient(135deg, #00ff7f, #39ff14);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(57, 255, 20, 0.5);
    color: var(--black);
}

.cart-drawer-btn-continue {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    background: transparent;
    color: var(--light-gray);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.cart-drawer-btn-continue:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.25);
}

/* Mobile Responsiveness */
@media (max-width: 480px) {
    .cart-drawer {
        width: 100%;
    }

    .cart-drawer-item-image {
        width: 80px;
        height: 80px;
    }

    .cart-drawer-item-name {
        font-size: 0.95rem;
    }

    /* Compact cart drawer header for mobile */
    .cart-drawer-header {
        padding: 0.5rem 0.75rem;
    }

    .cart-drawer-header-content {
        font-size: 0.95rem;
    }

    .cart-drawer-header-content i {
        font-size: 1rem;
    }

    /* Compact cart drawer summary for mobile */
    .cart-drawer-summary {
        padding: 0.5rem 0.75rem;
        margin-bottom: 0.75rem;
    }

    .cart-drawer-summary-row {
        padding: 0.25rem 0;
        font-size: 0.85rem;
    }

    .cart-drawer-total-row {
        font-size: 0.95rem;
        padding-top: 0.375rem;
    }

    /* Compact cart drawer body for mobile */
    .cart-drawer-body {
        padding: 0.75rem;
    }

    .cart-drawer-item {
        gap: 0.5rem;
        padding-bottom: 0.75rem;
        margin-bottom: 0.75rem;
    }

    /* Compact discount and shipping sections for mobile */
    .cart-drawer-discount-input {
        margin-bottom: 0.75rem;
    }

    .cart-drawer-discount-form {
        padding: 0.5rem 0.75rem;
    }

    .cart-drawer-shipping {
        padding: 0.5rem;
    }

    /* Compact related products section for mobile */
    .cart-drawer-related {
        margin-top: 0.5rem;
        padding-top: 0.5rem;
    }

    .cart-drawer-related-header {
        margin-bottom: 0.625rem;
    }

    .cart-drawer-related-title {
        font-size: 1rem;
    }

    .cart-drawer-title-icon {
        width: 20px !important;
        height: 20px !important;
    }

    .cart-drawer-related-cta {
        margin-top: 0.75rem;
        padding-top: 0.75rem;
    }

    /* Compact cart drawer footer for mobile */
    .cart-drawer-footer {
        padding: 0.75rem 0.75rem;
        flex-direction: row;
        gap: 0.375rem;
        flex-wrap: wrap;
    }

    .cart-drawer-btn-checkout,
    .cart-drawer-btn-cart {
        flex: 1;
        min-width: 0;
        padding: 0.625rem 0.5rem;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .cart-drawer-btn-checkout {
        order: 1;
    }

    .cart-drawer-btn-cart {
        order: 2;
    }

    .cart-drawer-btn-continue {
        order: 3;
        flex: 1 0 100%;
        padding: 0.5rem 0.5rem;
        font-size: 0.8rem;
        margin-top: 0.25rem;
    }

    /* Hide text on very small screens, show only icons */
    @media (max-width: 360px) {
        .cart-drawer-btn-checkout,
        .cart-drawer-btn-cart {
            padding: 0.5rem;
            font-size: 0.75rem;
        }

        .cart-drawer-btn-continue {
            padding: 0.4rem 0.5rem;
            font-size: 0.75rem;
        }
    }
}

/* Prevent body scroll when drawer is open */
body.cart-drawer-open {
    overflow: hidden;
}

/* Related Products Carousel */
.cart-drawer-related {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.cart-drawer-related-header {
    text-align: center;
    margin-bottom: 0.875rem;
}

.cart-drawer-related-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--neon-pink);
    margin-bottom: 0.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.cart-drawer-related-title i {
    color: var(--neon-pink);
    animation: pulse 2s infinite;
}

.cart-drawer-title-icon {
    animation: pulse 2s infinite;
}

.cart-drawer-related-subtitle {
    font-size: 0.8rem;
    color: var(--light-gray);
    margin: 0;
    font-style: italic;
}

.cart-drawer-related-cta {
    text-align: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.cart-drawer-browse-more {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: linear-gradient(45deg, var(--neon-pink), var(--hot-pink));
    color: var(--white);
    text-decoration: none;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.cart-drawer-browse-more:hover {
    background: linear-gradient(45deg, var(--hot-pink), var(--neon-pink));
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 0, 127, 0.4);
    color: var(--white);
}

.cart-drawer-carousel-container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.cart-drawer-carousel {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0.25rem 0;
    flex: 1;
}

.cart-drawer-carousel::-webkit-scrollbar {
    display: none;
}

.cart-drawer-carousel-btn {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.75rem;
}

.cart-drawer-carousel-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: var(--white);
}

.cart-drawer-carousel-btn:disabled {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
}

/* Product Card in Carousel */
.cart-drawer-product-card {
    flex-shrink: 0;
    width: 140px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: pointer;
}

.cart-drawer-product-card:hover {
    border-color: rgba(255, 0, 127, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
}

.cart-drawer-product-image {
    display: block;
    position: relative;
    width: 100%;
    height: 100px;
    background: rgba(0, 0, 0, 0.2);
    overflow: hidden;
}

.cart-drawer-product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.cart-drawer-product-card:hover .cart-drawer-product-image img {
    transform: scale(1.05);
}

.cart-drawer-quick-add {
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--neon-pink);
    color: var(--white);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.2s ease;
    font-size: 0.85rem;
    box-shadow: 0 3px 10px rgba(255, 0, 127, 0.4);
}

.cart-drawer-product-card:hover .cart-drawer-quick-add {
    opacity: 1;
    transform: scale(1);
}

.cart-drawer-quick-add:hover {
    background: #ff1493;
    transform: scale(1.1);
}

.cart-drawer-quick-add.adding {
    background: #39ff14;
}

.cart-drawer-product-info {
    display: block;
    padding: 0.6rem 0.75rem;
    text-decoration: none;
    color: var(--white);
}

.cart-drawer-product-name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--white);
    margin: 0 0 0.35rem 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    height: 2.6em;
}

.cart-drawer-product-rating {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 0.35rem;
}

.cart-drawer-product-stars {
    display: flex;
    gap: 1px;
}

.cart-drawer-product-stars i {
    font-size: 0.6rem;
    color: #ffc107;
}

.cart-drawer-product-stars i.empty {
    color: rgba(255, 255, 255, 0.2);
}

.cart-drawer-product-reviews {
    font-size: 0.65rem;
    color: var(--light-gray);
}

.cart-drawer-product-price {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--neon-pink);
}

/* Mobile adjustments for carousel */
@media (max-width: 480px) {
    .cart-drawer-product-card {
        width: 120px;
    }

    .cart-drawer-product-image {
        height: 80px;
    }

    .cart-drawer-product-name {
        font-size: 0.7rem;
    }

    .cart-drawer-carousel-btn {
        width: 24px;
        height: 24px;
        font-size: 0.65rem;
    }
}

