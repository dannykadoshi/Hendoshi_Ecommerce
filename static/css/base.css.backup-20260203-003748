}

.vault-submit-content {
    position: relative;
    z-index: 1;
}

.vault-submit-icon {
    font-size: 3rem;
    color: #ff1493;
    margin-bottom: 1rem;
    opacity: 0.8;
}

.vault-submit-title {
    color: #fff;
    text-shadow: 0 0 10px rgba(255, 20, 147, 0.8), 0 0 20px rgba(255, 20, 147, 0.6), 0 0 30px rgba(255, 20, 147, 0.4);
