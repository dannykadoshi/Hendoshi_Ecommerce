    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
}

.vault-featured-caption {
    font-weight: 600;
    color: #ff1493;
    font-size: 1rem;
    margin: 0;
    line-height: 1.2;
}

.vault-featured-user-container {
    height: 31px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
}

.vault-featured-user {
