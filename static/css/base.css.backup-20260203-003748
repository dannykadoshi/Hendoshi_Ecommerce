/* Sale hero - reusable across pages */
.sale-hero {
    position: relative;
    padding: 8rem 0 4rem;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 20, 147, 0.1);
    overflow: hidden;
    /* Lift the hero below sticky navbar */
    margin-top: 120px;
    padding-top: calc(8rem + 10px);
}

.sale-hero::before {
     content: '';
     position: absolute;
     top: 0;
     left: 0;
     right: 0;
     bottom: 0;
     background: radial-gradient(circle at 30% 70%, rgba(255, 20, 147, 0.06) 0%, rgba(255, 140, 0, 0.03) 30%, transparent 60%);
     pointer-events: none;
     z-index: 1;
}

.sale-title {
    font-size: 3rem;
    font-weight: 900;
    text-transform: none;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--neon-pink), var(--electric-yellow));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    position: relative;
    z-index: 2;
}

.sale-subtitle {
     font-size: 1.2rem;
     color: var(--off-white);
     opacity: 0.95;
     position: relative;
     z-index: 2;
}

.sale-badge {
     display: inline-block;
     margin-top: 1rem;
     padding: 0.5rem 0.9rem;
     background: linear-gradient(90deg, rgba(255,20,147,0.95), rgba(255,140,0,0.95));
     color: #fff;
     border-radius: 999px;
     font-weight: 800;
     letter-spacing: 1px;
     box-shadow: 0 8px 30px rgba(255,20,147,0.12);
     position: relative;
     z-index: 2;
}

/* Contact/Close button used on shipping, contact, returns, about pages */
.contact-close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--neon-pink);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    transition: color 0.3s, transform 0.2s;
    z-index: 10;
}

.contact-close-btn:hover {
    color: var(--electric-yellow);
    transform: scale(1.1);
}

/* Toast positioning moved from inline styles in templates */
.toast[data-message="true"] { position: relative; }

/* About page specific accents */
.about-vibrant .accent-title {
    font-size: 2rem;
    color: var(--neon-pink);
    font-weight: 900;
    letter-spacing: 1px;
    margin-bottom: 1rem;
    text-align: center !important;
}
.about-vibrant .lead {
    color: var(--off-white);
    opacity: 0.95;
    margin-bottom: 3rem;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-top: 1rem;
}
.about-vibrant .two-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}
.muted-hr {
    border: none;
    height: 1px;
    background: rgba(255,255,255,0.04);
    margin: 2rem 0;
}
.about-quote {
    font-style: italic;
    color: var(--electric-yellow);
    font-weight: 700;
    margin: 2rem 0;
    padding: 1rem;
    border-left: 4px solid var(--neon-pink);
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
}

.about-buttons {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin: 1.5rem 0;
    padding: 0 1rem;
}

.about-buttons .btn {
    min-width: 160px;
    text-align: center;
}
.about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}
.about-card {
    padding: 1rem;
    border-radius: 12px;
}
.about-vibrant h3 {
    color: var(--neon-pink);
    font-weight: 700;
    margin-bottom: 1rem;
    font-size: 1.25rem;
}
.about-card h4 {
    margin-bottom: 0.75rem;
    color: var(--neon-pink);
    font-weight: 700;
    font-size: 1.1rem;
}
.tight { margin-top: 1rem; }
.small.muted { color: rgba(255,255,255,0.6); font-size: 0.9rem; }

@media (max-width: 768px) {
    .about-vibrant .two-columns { grid-template-columns: 1fr; }
}

/* Layout fixes for symmetric About page */
.contact-card {
    margin: 0 auto;
    max-width: 1200px; /* Constrain width on large screens for better readability */
    padding: 2rem;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
}

/* Policy Pages Specific Styling (Privacy, Terms, etc.) */
.contact-card h2 {
    color: var(--neon-pink);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    z-index: 2;
}

.contact-card h2:first-of-type {
    margin-top: 1rem;
    border-top: none;
    padding-top: 0;
}

.contact-card p {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 1rem;
    position: relative;
    z-index: 2;
}

.contact-card p:last-child {
    margin-bottom: 0;
}

.contact-card ul {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    position: relative;
    z-index: 2;
}

.contact-card ul li {
    margin-bottom: 0.75rem;
}

.contact-card ul li:last-child {
    margin-bottom: 0;
}

.contact-card strong {
    color: rgba(255, 255, 255, 0.95);
    font-weight: 600;
}

.contact-card a {
    color: var(--neon-pink);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
    position: relative;
    z-index: 2;
}

.contact-card a:hover {
    color: #ff6fb5;
    text-decoration: underline;
}

/* Mobile Responsive Styles for Policy Pages */
@media (max-width: 991px) {
    .contact-card {
        padding: 1.75rem 1.5rem;
    }

    .contact-card h2 {
        font-size: 1.35rem;
        margin-top: 2rem;
        margin-bottom: 0.85rem;
    }

    .contact-card p,
    .contact-card ul {
        font-size: 0.95rem;
        line-height: 1.7;
    }
}

@media (max-width: 768px) {
    .contact-page {
        padding-top: 100px;
    }

    .contact-card {
        padding: 1.5rem 1.25rem;
        border-radius: 0;
    }

    .contact-card h2 {
        font-size: 1.25rem;
        margin-top: 1.75rem;
        margin-bottom: 0.75rem;
        padding-top: 0.75rem;
    }

    .contact-card h2:first-of-type {
        margin-top: 0.75rem;
    }

    .contact-card p {
        font-size: 0.9rem;
        line-height: 1.65;
        margin-bottom: 1rem;
    }

    .contact-card ul {
        font-size: 0.9rem;
        line-height: 1.65;
        margin-bottom: 1.25rem;
        padding-left: 1.25rem;
    }

    .contact-card ul li {
        margin-bottom: 0.65rem;
    }
}

@media (max-width: 576px) {
    .contact-page {
        padding-top: 90px;
    }

    .contact-card {
        padding: 1.25rem 1rem;
    }

    .contact-card h2 {
        font-size: 1.15rem;
        margin-top: 1.5rem;
        margin-bottom: 0.65rem;
        padding-top: 0.65rem;
    }

    .contact-card h2:first-of-type {
        margin-top: 0.5rem;
    }

    .contact-card p {
        font-size: 0.875rem;
        line-height: 1.6;
        margin-bottom: 0.9rem;
    }

    .contact-card ul {
        font-size: 0.875rem;
        line-height: 1.6;
        margin-bottom: 1rem;
        padding-left: 1rem;
    }

    .contact-card ul li {
        margin-bottom: 0.55rem;
    }

    /* Improve link tap targets on mobile */
    .contact-card a {
        display: inline-block;
        padding: 2px 0;
        min-height: 44px;
        line-height: 1.6;
    }
}

/* Contact Page Specific Styles */
.form-hint {
    color: #aaa;
}

.contact-form .form-label {
    color: #fff;
    font-weight: 500;
    margin-bottom: 0.5rem;
}

.contact-form .form-label i {
    color: var(--neon-pink);
    margin-right: 0.5rem;
}

.contact-form .required {
