.summary-title { color: var(--off-white); font-weight:800; }

.checkout-cta .checkout-btn { background: linear-gradient(90deg, rgba(255,105,180,0.95), rgba(255,235,59,0.95)); border:none; color:var(--black); box-shadow:0 8px 30px rgba(0,0,0,0.12); }
.checkout-cta .checkout-btn.disabled { opacity:0.6; pointer-events:none; }

.btn-remove { width:40px; height:40px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; background: rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.03); }
.btn-remove:hover { transform: scale(1.08); box-shadow: 0 6px 18px rgba(0,0,0,0.12); }

/* Mobile stacking */
@media (max-width: 991px) {
    .cart-item { grid-template-columns: 80px 1fr; grid-auto-rows: auto; grid-template-areas: "img details" "img quantity" "img subtotal" "img actions"; gap:0.5rem; }
