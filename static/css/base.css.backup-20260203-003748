.cart-item-price, .cart-item-subtotal { text-align: right; font-weight:700; color:var(--off-white); }

.qty-btn-sm { width:36px; height:36px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; }
.qty-btn-sm:hover { transform: scale(1.05); }
.qty-input-sm { width:64px; border-radius:8px; padding:6px 8px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.03); text-align:center; }

.cart-item-actions, .cart-item-quantity { display:flex; align-items:center; justify-content:center; }

.cart-summary { padding: 1.75rem !important; }
