/* Mobile responsiveness for recently viewed products carousel */
@media (max-width: 768px) {
    .recently-viewed-products-carousel {
        padding: 0 50px 0 0;
    }
    
    .recently-viewed-products-track {
        padding: 0;
        gap: 1rem; /* Reduce gap on mobile */
    }
    
    .recently-viewed-product-item {
        flex: 0 0 200px;
        width: 200px;
    }
    
    .recently-viewed-products-carousel .product-card {
        height: auto;
    }
    
    .recently-viewed-products-carousel .product-image {
        /* Use 4:5 portrait ratio to match main product cards */
        aspect-ratio: 4 / 5;
    }
    
    .recently-viewed-products-carousel-btn {
        width: 35px;
        height: 35px;
        opacity: 0.5;
    }
    
    .recently-viewed-products-carousel-prev {
        left: 20px;
    }
    
    .recently-viewed-products-carousel-next {
        right: 5px;
    }
}

