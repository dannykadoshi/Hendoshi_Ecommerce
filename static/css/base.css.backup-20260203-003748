/* Related Products Carousel */
.related-products-carousel-container {
    position: relative;
    z-index: 10;
    margin-bottom: 3rem; /* Space between carousel and footer line */
}

.related-products-carousel {
    position: relative;
    overflow: hidden;
}

.related-products-track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.3s ease;
    padding: 0 60px 0 0; /* Remove left padding, keep right padding for navigation */
    touch-action: pan-y; /* Allow vertical scrolling, horizontal swipes for carousel */
    overflow-x: auto; /* Allow manual horizontal scrolling */
    scrollbar-width: none; /* Hide scrollbar in Firefox */
    -ms-overflow-style: none; /* Hide scrollbar in IE/Edge */
    scroll-behavior: smooth; /* Smooth scrolling */
    scroll-snap-type: x mandatory; /* Snap to cards */
}

.related-products-track::-webkit-scrollbar {
    display: none; /* Hide scrollbar in Webkit browsers */
}

.related-product-item {
    flex: 0 0 210px;
    min-width: 210px;
    scroll-snap-align: start; /* Snap to start of each card */
}

.related-products-carousel .product-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    height: auto;
    transition: all 0.4s ease;
    position: relative;
    overflow: visible;
    margin-bottom: 0;
}

.related-products-carousel .product-card a {
    position: relative;
    z-index: 2;
    display: block;
}

.related-products-carousel .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 20, 147, 0.1) 0%, rgba(0, 255, 0, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
}

.related-products-carousel .product-card:hover::before {
    opacity: 1;
}

.related-products-carousel .product-card:hover {
    margin-top: -8px;
    box-shadow: 0 15px 35px rgba(255, 20, 147, 0.2);
    border-color: rgba(255, 20, 147, 0.3);
    z-index: 1000;
}

/* Allow cards to lift above carousel bounds */
.related-products-carousel:has(.product-card:hover) {
    overflow: visible;
}

.related-products-carousel .product-image {
    position: relative;
    width: 100%;
    /* Use 4:5 portrait ratio to match main product cards */
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 16px 16px 0 0;
}

.related-products-carousel .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.related-products-carousel .product-card:hover .product-image img {
    transform: scale(1.05);
}

.related-products-carousel .product-info {
    padding: 1.25rem;
    padding-bottom: 4rem;
    position: relative;
    z-index: 2;
}

.related-products-carousel .product-info h3 {
    color: var(--white);
