{% extends 'base.html' %}
{% load static %}

{% block extra_title %}Join The Vault - Become a HENDOSHI Legend{% endblock %}

{% block content %}
<div class="vault-page">
    <!-- Submit Photo Hero -->
    <section class="vault-hero">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <img src="{% static 'images/pug-skull.webp' %}" alt="HENDOSHI Pug Skull" class="pug-skull-branding mb-3" loading="lazy">
                    <h1 class="vault-hero-title">Submit Photo</h1>
                    <p class="vault-hero-subtitle">Join the elite HENDOSHI community. Share your killer style and inspire the weirdos of tomorrow.</p>
                    <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                        <a href="{% url 'vault:vault_gallery' %}" class="btn btn-outline-pink">
                            <i class="fas fa-arrow-left"></i> Back to Gallery
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="container vault-container">

    <!-- Main Form Card -->
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="vault-submit-card glassmorphic-card">
                <!-- Header -->
                <div class="vault-submit-header">
                    <div class="vault-submit-header-icon">
                        <i class="fas fa-camera-retro"></i>
                    </div>
                    <h2 class="vault-submit-title">Share Your HENDOSHI Moment</h2>
                    <p class="vault-submit-description">
                        Got that perfect shot of you rocking HENDOSHI gear? Upload it here and let the community see your style!
                        Your photo could become featured and inspire countless weirdos worldwide.
                    </p>
                </div>

                <form method="post" enctype="multipart/form-data" id="submit-form" novalidate>
                    {% csrf_token %}

                    <!-- Upload Zone -->
                    <div class="vault-upload-zone" id="uploadZone">
                        <div class="vault-upload-content">
                            <div class="vault-upload-icon">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <h3 class="vault-upload-title">Drop Your Photo Here</h3>
                            <p class="vault-upload-subtitle" id="browse-text">Or click to browse your files</p>
                            <div class="vault-upload-requirements">
                                <span class="requirement-item"><i class="fas fa-check"></i> JPG/PNG only</span>
                                <span class="requirement-item"><i class="fas fa-check"></i> Max 5MB</span>
                                <span class="requirement-item"><i class="fas fa-check"></i> Show your HENDOSHI gear</span>
                            </div>
                        </div>
                        <input type="file" name="image" id="id_image" class="vault-file-input" accept="image/*">
                        <div class="vault-upload-preview d-none" id="uploadPreview">
                            <img id="previewImage" src="" alt="Preview">
                            <button type="button" class="vault-preview-remove" id="removePreview">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Caption Section -->
                    <div class="vault-form-section">
                        <div class="vault-section-header">
                            <i class="fas fa-comment-dots section-icon"></i>
                            <h3 class="section-title">Tell Your Story</h3>
                        </div>
                        <div class="vault-form-group">
                            <label for="id_caption" class="vault-form-label">
                                What's the vibe? What's the story behind this look?
                            </label>
                            <textarea name="caption" id="id_caption" class="vault-form-textarea" maxlength="800"
                                      placeholder="Example: 'Crushing leg day in my favorite HENDOSHI skull tee. This design hits different when you're pushing limits! 💀🏋️‍♂️'"></textarea>
                            <div class="vault-char-counter">
                                <span id="char-count">0</span>/800 characters
                            </div>
                        </div>
                    </div>

                    <!-- Product Tagging Section -->
                    <div class="vault-form-section">
                        <div class="vault-section-header">
                            <i class="fas fa-tags section-icon"></i>
                            <h3 class="section-title">Tag Your Gear</h3>
                        </div>
                        <div class="vault-form-group">
                            <label class="vault-form-label">
                                Which HENDOSHI products are you wearing? Help others discover our gear!
                            </label>
                            <div class="position-relative">
                                <div class="vault-multi-select" id="product_tags">
                                    <div class="vault-selected-tags" id="selected_tags"></div>
                                    <input type="text" class="vault-tag-input" id="tag_input" placeholder="Search for products you're wearing..." autocomplete="off">
                                </div>
                                <input type="hidden" name="products" id="product_ids">
                                <div id="product_dropdown" class="vault-multi-dropdown">
                                    {% for product in all_products %}
                                    <div class="vault-dropdown-item" data-value="{{ product.id }}" data-name="{{ product.name }}">
                                        {{ product.name }}
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                            <div class="vault-form-help">
                                <i class="fas fa-lightbulb"></i> Tagging products helps your photo get discovered and featured!
                            </div>
                        </div>
                    </div>

                    <!-- Rules & Consent -->
                    <div class="vault-form-section">
                        <div class="vault-rules-card">
                            <h4 class="rules-title">
                                <i class="fas fa-scroll rules-icon"></i>
                                Vault Commandments
                            </h4>
                            <div class="rules-list">
                                <div class="rule-item">
                                    <i class="fas fa-check-circle rule-check"></i>
                                    <span>Show off your HENDOSHI gear proudly</span>
                                </div>
                                <div class="rule-item">
                                    <i class="fas fa-check-circle rule-check"></i>
                                    <span>Be respectful and keep it real</span>
                                </div>
                                <div class="rule-item">
                                    <i class="fas fa-check-circle rule-check"></i>
                                    <span>No nudity, hate, or illegal content</span>
                                </div>
                                <div class="rule-item">
                                    <i class="fas fa-check-circle rule-check"></i>
                                    <span>Original photos only (no stock images)</span>
                                </div>
                            </div>
                        </div>

                        <div class="vault-consent-section">
                            <div class="form-check">
                                <input class="form-check-input vault-consent-checkbox" type="checkbox" id="consent">
                                <label class="form-check-label vault-consent-label" for="consent">
                                    <strong>I solemnly swear</strong> that this photo is mine, shows HENDOSHI gear, and I'm cool with it being displayed publicly in The Vault gallery for the greater good of the weird community.
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Section -->
                    <div class="vault-submit-section">
                        <div class="vault-submit-actions">
                            <a href="{% url 'vault:vault_gallery' %}" class="btn vault-back-btn btn-lg">
                                <i class="fas fa-arrow-left"></i> Back to Gallery
                            </a>
                            <button type="button" class="btn vault-submit-btn btn-lg" id="submit-btn" onclick="handlePhotoSubmission()">
                                <i class="fas fa-rocket"></i> Launch My Photo
                                <div class="btn-shine"></div>
                            </button>
                        </div>
                        <div class="vault-submit-note">
                            <i class="fas fa-clock"></i>
                            Your photo will be reviewed by our moderators before appearing in The Vault.
                            We'll notify you once it's approved!
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    </div>
</div>
{% endblock %}

{% block extra_css %}

{% endblock %}

{% block extra_js %}
<script src="{% static 'js/vault.js' %}"></script>
<script>
// Enhanced upload zone functionality
document.addEventListener('DOMContentLoaded', function() {
    const uploadZone = document.getElementById('uploadZone');
    const fileInput = document.getElementById('id_image');
    const uploadContent = document.querySelector('.vault-upload-content');
    const uploadPreview = document.getElementById('uploadPreview');
    const previewImage = document.getElementById('previewImage');
    const removePreview = document.getElementById('removePreview');

    // Drag and drop functionality
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        uploadZone.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }

    ['dragenter', 'dragover'].forEach(eventName => {
        uploadZone.addEventListener(eventName, highlight, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        uploadZone.addEventListener(eventName, unhighlight, false);
    });

    function highlight(e) {
        uploadZone.classList.add('dragover');
    }

    function unhighlight(e) {
        uploadZone.classList.remove('dragover');
    }

    uploadZone.addEventListener('drop', handleDrop, false);

    function handleDrop(e) {
        const dt = e.dataTransfer;
        const files = dt.files;
        handleFiles(files);
    }

    function handleFiles(files) {
        if (files.length > 0) {
            fileInput.files = files;
            previewFile(files[0]);
        }
    }

    // Click on preview to change file
    uploadPreview.addEventListener('click', function(e) {
        // Don't trigger if clicking on the remove button
        if (e.target === removePreview || e.target.closest('.vault-preview-remove')) {
            return;
        }
        fileInput.click();
    });

    // File input change
    fileInput.addEventListener('change', function() {
        if (this.files[0]) {
            handleFiles(this.files);
        }
    });

    // Preview functionality
    function previewFile(file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            previewImage.src = e.target.result;
            uploadContent.classList.add('d-none');
            uploadPreview.classList.remove('d-none');
        };
        reader.readAsDataURL(file);
    }

    // Remove preview
    removePreview.addEventListener('click', function(e) {
        e.stopPropagation();
        fileInput.value = '';
        uploadContent.classList.remove('d-none');
        uploadPreview.classList.add('d-none');
    });

    // Character counter
    const captionTextarea = document.getElementById('id_caption');
    const charCount = document.getElementById('char-count');

    captionTextarea.addEventListener('input', function() {
        const count = this.value.length;
        charCount.textContent = count;
        if (count > 720) {
            charCount.style.color = '#dc3545';
        } else {
            charCount.style.color = '#888';
        }
    });

    // Form validation
    const form = document.getElementById('submit-form');
    const submitBtn = document.getElementById('submit-btn');

    // Function to handle photo submission (called by button onclick)
    window.handlePhotoSubmission = function() {
        const consentCheckbox = document.getElementById('consent');

        if (!fileInput.files[0]) {
            showValidationModal('Please select an image to upload.', 'Missing Image', 'fa-image');
            return;
        }

        // Check file size (5MB)
        if (fileInput.files[0].size > 5 * 1024 * 1024) {
            showValidationModal('File size must be less than 5MB.', 'File Too Large', 'fa-file-alt');
            return;
        }

        // Check file type
        const allowedTypes = ['image/jpeg', 'image/png', 'image/jpg'];
        if (!allowedTypes.includes(fileInput.files[0].type)) {
            showValidationModal('Only JPG and PNG files are allowed.', 'Invalid File Type', 'fa-file-image');
            return;
        }

        if (!consentCheckbox.checked) {
            showValidationModal('Please agree to the terms before submitting.', 'Terms Required', 'fa-handshake');
            return;
        }

        // If all validations pass, submit the form
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Launching Your Photo...';
        form.submit();
    };
});
</script>

<!-- Validation Modal -->
<div class="modal fade vault-confirm-modal" id="vaultValidationModal" tabindex="-1" aria-labelledby="vaultValidationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content vault-modal-content">
            <div class="modal-header vault-modal-header">
                <h5 class="modal-title vault-modal-title" id="vaultValidationModalLabel">
                    <i class="fas fa-exclamation-triangle vault-modal-icon"></i>
                    <span id="validation-modal-title">Validation Error</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body vault-modal-body">
                <div class="vault-modal-message-wrapper">
                    <div class="vault-modal-icon-wrapper">
                        <i class="fas fa-exclamation-circle vault-modal-main-icon" id="validation-modal-icon"></i>
                    </div>
                    <p class="vault-modal-message" id="validation-modal-message">Please check your input and try again.</p>
                </div>
            </div>
            <div class="modal-footer vault-modal-footer">
                <button type="button" class="btn vault-modal-btn-confirm btn-danger" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> <span id="validation-modal-confirm-text">OK</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// Function to show validation modal instead of alert
function showValidationModal(message, title = 'Validation Error', icon = 'fa-exclamation-circle') {
    document.getElementById('validation-modal-title').textContent = title;
    document.getElementById('validation-modal-message').textContent = message;
    document.getElementById('validation-modal-icon').className = `fas ${icon} vault-modal-main-icon`;

    const modal = new bootstrap.Modal(document.getElementById('vaultValidationModal'));
    modal.show();
}
</script>
{% endblock %}