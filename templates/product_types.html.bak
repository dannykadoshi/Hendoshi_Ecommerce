{% extends 'base.html' %}
{% load static %}

{% block extra_title %}Product Types{% endblock %}

{% block content %}
<div class="vault-page">
    <!-- Product Types Hero -->
    <section class="vault-hero">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <img src="{% static 'images/pug-skull.webp' %}" alt="HENDOSHI Pug Skull" class="pug-skull-branding mb-3" loading="lazy">
                    <h1 class="vault-hero-title">Shop by Product Type</h1>
                    <p class="vault-hero-subtitle">Find exactly what you're looking for</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container-fluid vault-container">
                {% if product_types %}
                <div class="products-grid">
                    {% for product_type in product_types %}
                    <div class="product-card-wrapper">
                        <div class="product-card glassmorphic-card" onclick="window.location.href='{% url 'products' %}?type={{ product_type.slug }}'" style="cursor: pointer;">
                            <div class="product-card-inner">
                                <div class="product-image product-image-relative">
                                    {% if product_type.representative_product and product_type.representative_product.main_image %}
                                        <img src="{{ product_type.representative_product.main_image.url }}" alt="{{ product_type.representative_product.name }}" class="product-img-main" loading="lazy">
                                    {% else %}
                                        <div class="placeholder-image">
                                            <i class="fas fa-shopping-bag fa-3x"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="product-info">
                                    <h3>{{ product_type.name }}</h3>
                                    <p class="product-type">Product Type</p>
                                    <p class="product-price">{{ product_type.product_count }} Product{{ product_type.product_count|pluralize }}</p>
                                    <div class="product-type-link">
                                        <span>Shop {{ product_type.name }}</span>
                                        <i class="fas fa-arrow-right"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center">
                    <h3>No product types available at the moment.</h3>
                    <p>Check back soon for new product categories!</p>
                </div>
                {% endif %}
            </div>
        </section>
    </div>
</div>

<style>
/* Vault Page Hero Styles */
.vault-page {
    min-height: 100vh;
    padding-top: 120px;
}

/* Mobile optimization for hero */
@media (max-width: 768px) {
}

@media (max-width: 576px) {
}

/* Glassmorphism Effects */
.glassmorphic-card {
    background: rgba(255, 255, 255, 0.03) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 15px !important;
}

.glassmorphic-card:hover {
    background: rgba(255, 255, 255, 0.05) !important;
    border-color: rgba(255, 105, 180, 0.3) !important;
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(255, 20, 147, 0.4);
}

.product-types-hero {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 80px 0;
    margin-top: -20px;
}

.product-types-title {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--neon-pink), var(--electric-yellow));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.product-types-subtitle {
    font-size: 1.2rem;
    color: #ccc;
    margin-bottom: 0;
}

/* Product type card styles to match products page */
.product-card-wrapper {
    width: 100%;
}

.product-card {
    height: 100%;
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid rgba(255, 20, 147, 0.2);
    border-radius: 15px;
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
}

.product-card:hover {
    border-color: var(--neon-pink);
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(255, 20, 147, 0.3);
}

.product-card-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
}

.product-image {
    position: relative;
    overflow: hidden;
    /* Portrait 4:5 ratio to match product cards across site */
    aspect-ratio: 4 / 5;
    background: rgba(0, 0, 0, 0.5);
}

.product-img-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.product-card:hover .product-img-main {
    transform: scale(1.05);
}

.product-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.product-info h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--off-white);
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
}

.product-card:hover .product-info h3 {
    color: var(--neon-pink);
}

.product-type {
    font-size: 0.85rem;
    color: var(--electric-yellow);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.product-price {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--neon-pink);
    margin-bottom: 1rem;
}

.product-type-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--neon-pink);
    font-weight: 500;
    transition: color 0.3s ease;
    margin-top: auto;
}

.product-card:hover .product-type-link {
    color: var(--electric-yellow);
}

.placeholder-image {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
}

.placeholder-image i {
    margin-bottom: 0.5rem;
}

@media (max-width: 768px) {
    .product-types-title {
        font-size: 2rem;
    }
}
</style>

{% endblock %}